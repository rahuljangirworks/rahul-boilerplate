{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "rahul-boilerplate",
  "homepage": "https://github.com/rahuljangirwork/rahul-boilerplate",
  "items": [
    {
      "name": "use-mobile",
      "type": "registry:hook",
      "files": [
        {
          "path": "registry/hooks/use-mobile.ts",
          "type": "registry:hook",
          "target": "hooks/use-mobile.ts"
        }
      ]
    },
    {
      "name": "auth-login-card",
      "type": "registry:block",
      "dependencies": [
        "lucide-react",
        "zod",
        "react-hook-form",
        "@hookform/resolvers"
      ],
      "registryDependencies": [
        "button",
        "card",
        "input",
        "label"
      ],
      "files": [
        {
          "path": "registry/blocks/auth/auth-login-card.tsx",
          "type": "registry:block",
          "target": "components/auth-login-card.tsx"
        }
      ],
      "category": "Authentication"
    },
    {
      "name": "landing-saas-home",
      "type": "registry:block",
      "dependencies": [
        "lucide-react"
      ],
      "registryDependencies": [
        "button"
      ],
      "files": [
        {
          "path": "registry/blocks/landing/landing-saas-home.tsx",
          "type": "registry:block",
          "target": "components/landing-saas-home.tsx"
        }
      ],
      "category": "Marketing"
    },
    {
      "name": "dashboard-sidebar-layout",
      "type": "registry:block",
      "dependencies": [
        "lucide-react"
      ],
      "registryDependencies": [
        "button",
        "sheet",
        "dropdown-menu",
        "sidebar",
        "breadcrumb",
        "input"
      ],
      "files": [
        {
          "path": "registry/blocks/dashboard/dashboard-sidebar-layout.tsx",
          "type": "registry:block",
          "target": "components/dashboard-sidebar-layout.tsx"
        }
      ],
      "category": "Dashboard"
    }
  ]
}
