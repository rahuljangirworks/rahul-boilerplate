# =============================================================================
# REQUIRED — App will not start without these
# =============================================================================

# Database (Turso/libSQL)
# Use libsql://your-db.turso.io for Turso cloud
# Use file:./local.db for local SQLite (set AUTH_TOKEN to any non-empty string)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Auth (Better Auth)
# BETTER_AUTH_SECRET must be at least 32 random characters
# Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:5173

# =============================================================================
# OPTIONAL — App runs fully without these; modules degrade gracefully
# =============================================================================

# Email (Resend)
# Required only if using the email extension module
RESEND_API_KEY=re_xxxxxxxxxxxx

# File Storage (Cloudflare R2)
# Required only if using the upload extension module
# Never expose R2 credentials client-side
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name

# Public URL (used for generated links)
# Defaults to BETTER_AUTH_URL if not set
PUBLIC_APP_URL=http://localhost:5173
