{
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/((?!_assets|favicon\\.ico|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
